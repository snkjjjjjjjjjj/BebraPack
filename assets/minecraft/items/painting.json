    "component": "painting/variant",
    "cases": [
      {
        "model": {
          "type": "model",
          "model": "tooltrims:item/linear_template"
        },
        "when": "tooltrims:a_linear_template"
      },
      {
        "model": {
          "type": "model",
          "model": "tooltrims:item/tracks_template"
        },
        "when": "tooltrims:b_tracks_template"
      },
      {
        "model": {
          "type": "model",
          "model": "tooltrims:item/frost_template"
        },
        "when": "tooltrims:c_frost_template"
      },
      {
        "model": {
          "type": "model",
          "model": "tooltrims:item/charge_template"
        },
        "when": "tooltrims:d_charge_template"
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/painting"
    }
  }
